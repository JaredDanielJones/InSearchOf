# Copy this file to .env.local and fill in your values

# Anthropic API key — required for AI filtering
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ScraperAPI key — required for Craigslist searches
# Craigslist blocks all cloud/datacenter IPs (Firebase, Vercel, AWS, etc.)
# ScraperAPI routes requests through residential IPs that Craigslist allows.
# Free tier: 1,000 calls/month — enough for personal use.
# Get a free key at https://www.scraperapi.com/
SCRAPER_API_KEY=your-scraperapi-key-here
